PORT=4000
NODE_ENV=development

# Local dev: matches docker-compose.yml's postgres service
DB_HOST=localhost
DB_PORT=5432
DB_NAME=minishop
DB_USER=minishop_admin
DB_PASSWORD=localdevpassword
DB_SSL=false

# In ECS (later step) these get overridden with real RDS values,
# pulled from Secrets Manager via the task definition - never
